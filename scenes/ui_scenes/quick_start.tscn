[node name="Rules1" type="RichTextLabel" parent="Panel/VBoxContainer" unique_id=657691719]
custom_minimum_size = Vector2(500, 0)
layout_mode = 2
theme = ExtResource("2_678y5")
bbcode_enabled = true
text = "[font_size=36][color=lightblue]1. Play Baseball With Dice[/color][/font_size]
Rolling two matching colors grants a special bonus
When batting, roll to advance players on the bases
Roll a total above [color=red]STRIKE[/color] to avoid getting out
When pitching, roll to stop enemy players
Roll a total above [color=red]STRIKE[/color] to avoid them advancing too far
(See BATTING and PITCHING in RULES)"
fit_content = true
autowrap_mode = 2
horizontal_alignment = 1

[node name="Rules2" type="RichTextLabel" parent="Panel/VBoxContainer" unique_id=1696879027]
custom_minimum_size = Vector2(500, 0)
layout_mode = 2
theme = ExtResource("2_678y5")
bbcode_enabled = true
text = "[font_size=36][color=lightblue]2. Advance Batters to Score Points[/color][/font_size]
Crossing 4 bases scores 1 point
If there is a batter on a base, you can attempt
 to [color=cyan]STEAL[/color] or [color=cyan]TAG OUT[/color] the player with a dice roll
(See SPECIAL in RULES)
"
fit_content = true
autowrap_mode = 2
horizontal_alignment = 1

